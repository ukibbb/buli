{
  "name": "buli",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "bun": ">=1.3.12"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun run --workspaces --if-present test",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "build:cli": "bun --filter @buli/cli build",
    "dev:cli": "bun --filter @buli/cli dev",
    "link:cli": "bun scripts/link-cli.mjs",
    "login": "bun --filter @buli/cli login",
    "eval": "bun packages/performance/src/runBuliEvals.ts",
    "profile": "bun packages/performance/src/runBuliPerformanceProfile.ts",
    "profile:compare": "bun packages/performance/src/compareBuliPerformanceProfiles.ts",
    "profile:manual": "bun packages/performance/src/runManualBuliProfile.ts",
    "profile:report": "bun packages/performance/src/reportBuliProfileRun.ts",
    "start:cli": "bun --filter @buli/cli start"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "react-reconciler": "0.33.0"
  }
}
