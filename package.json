{
  "name": "buli",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "bun": ">=1.3.12"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun run --workspaces --if-present test",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "build:cli": "bun --filter @buli/cli build",
    "dev:cli": "bun --filter @buli/cli dev",
    "link:cli": "bun scripts/link-cli.mjs",
    "login": "bun --filter @buli/cli login",
    "start:cli": "bun --filter @buli/cli start"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "react-reconciler": "0.33.0"
  }
}
