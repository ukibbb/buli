{
  "name": "@buli/cli",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.12"
  },
  "bin": {
    "buli": "./bin/buli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "dependencies": {
    "@buli/contracts": "workspace:*",
    "@buli/engine": "workspace:*",
    "@buli/openai": "workspace:*",
    "@buli/tui": "workspace:*",
    "@shikijs/core": "^4.1.0",
    "@shikijs/engine-javascript": "^4.1.0",
    "@shikijs/langs": "^4.1.0",
    "@shikijs/themes": "^4.1.0",
    "marked": "^17.0.1",
    "open": "^10.2.0"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts ./src/providerProtocol/openAiProviderHostEntrypoint.ts --target=bun --outdir ./dist --entry-naming [name].js --external @buli/tui",
    "dev": "bun build ./src/cli.ts ./src/providerProtocol/openAiProviderHostEntrypoint.ts --target=bun --outdir ./dist --entry-naming [name].js --watch --external @buli/tui",
    "schema:conversation-session": "bun scripts/writeConversationSessionSqliteSchema.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "login": "bun src/cli.ts login",
    "start": "bun src/cli.ts",
    "prepublishOnly": "bun run build"
  }
}
