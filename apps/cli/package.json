{
  "name": "@buli/cli",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.12"
  },
  "bin": {
    "buli": "./bin/buli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "dependencies": {
    "@buli/engine": "workspace:*",
    "@buli/ink-tui": "workspace:*",
    "@buli/openai": "workspace:*",
    "@buli/opentui-tui": "workspace:*"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --target=bun --outdir ./dist --entry-naming cli.js --external @buli/ink-tui --external @buli/opentui-tui",
    "dev": "bun build ./src/cli.ts --target=bun --outdir ./dist --entry-naming cli.js --watch --external @buli/ink-tui --external @buli/opentui-tui",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "login": "bun src/cli.ts login",
    "start": "bun src/cli.ts",
    "prepublishOnly": "bun run build"
  }
}
