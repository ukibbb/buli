{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "bash"
        },
        "shellCommand": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20000
        },
        "commandDescription": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "workingDirectoryPath": {
          "$ref": "#/$defs/__schema0"
        },
        "timeoutMilliseconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 300000
        }
      },
      "required": [
        "toolName",
        "shellCommand",
        "commandDescription"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "read"
        },
        "readTargetPath": {
          "$ref": "#/$defs/__schema0"
        },
        "offsetLineNumber": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "maximumLineCount": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "toolName",
        "readTargetPath"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "read_many"
        },
        "readTargets": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema1"
          }
        }
      },
      "required": [
        "toolName",
        "readTargets"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "search_many"
        },
        "searches": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema2"
          }
        }
      },
      "required": [
        "toolName",
        "searches"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "glob"
        },
        "globPattern": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "searchDirectoryPath": {
          "$ref": "#/$defs/__schema0"
        }
      },
      "required": [
        "toolName",
        "globPattern"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "grep"
        },
        "regexPattern": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "searchPath": {
          "$ref": "#/$defs/__schema0"
        },
        "includeGlobPattern": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "contextLineCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      },
      "required": [
        "toolName",
        "regexPattern"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "edit"
        },
        "editTargetPath": {
          "$ref": "#/$defs/__schema0"
        },
        "oldString": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000000
        },
        "newString": {
          "type": "string",
          "maxLength": 1000000
        }
      },
      "required": [
        "toolName",
        "editTargetPath",
        "oldString",
        "newString"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "edit_many"
        },
        "edits": {
          "minItems": 1,
          "maxItems": 100,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema3"
          }
        }
      },
      "required": [
        "toolName",
        "edits"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "patch"
        },
        "patchText": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000000,
          "pattern": "^\\s*\\*\\*\\* Begin Patch\\n(?:[ \\t]*\\n)*(?:\\*\\*\\* (?:Add File|Update File|Delete File): [^\\n]+\\n?)(?:(?!\\n\\*\\*\\* (?:Add File|Update File|Delete File):)[\\s\\S])*\\n\\*\\*\\* End Patch\\s*$"
        }
      },
      "required": [
        "toolName",
        "patchText"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "patch_many"
        },
        "patchText": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000000,
          "pattern": "^\\s*\\*\\*\\* Begin Patch\\n[\\s\\S]*\\*\\*\\* (?:Add File|Update File|Delete File): [^\\n]+[\\s\\S]*\\n\\*\\*\\* End Patch\\s*$"
        }
      },
      "required": [
        "toolName",
        "patchText"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "write"
        },
        "writeTargetPath": {
          "$ref": "#/$defs/__schema0"
        },
        "fileContent": {
          "type": "string",
          "maxLength": 1000000
        }
      },
      "required": [
        "toolName",
        "writeTargetPath",
        "fileContent"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "const": "task"
        },
        "subagentName": {
          "type": "string",
          "enum": [
            "explore"
          ]
        },
        "subagentDescription": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "subagentPrompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100000
        }
      },
      "required": [
        "toolName",
        "subagentName",
        "subagentDescription",
        "subagentPrompt"
      ],
      "additionalProperties": false
    }
  ],
  "$defs": {
    "__schema0": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "__schema1": {
      "type": "object",
      "properties": {
        "readTargetPath": {
          "$ref": "#/$defs/__schema0"
        },
        "offsetLineNumber": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "maximumLineCount": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "readTargetPath"
      ],
      "additionalProperties": false
    },
    "__schema2": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "searchKind": {
              "type": "string",
              "const": "glob"
            },
            "globPattern": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096
            },
            "searchDirectoryPath": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "required": [
            "searchKind",
            "globPattern"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "searchKind": {
              "type": "string",
              "const": "grep"
            },
            "regexPattern": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096
            },
            "searchPath": {
              "$ref": "#/$defs/__schema0"
            },
            "includeGlobPattern": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096
            },
            "contextLineCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            }
          },
          "required": [
            "searchKind",
            "regexPattern"
          ],
          "additionalProperties": false
        }
      ]
    },
    "__schema3": {
      "type": "object",
      "properties": {
        "editTargetPath": {
          "$ref": "#/$defs/__schema0"
        },
        "oldString": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000000
        },
        "newString": {
          "type": "string",
          "maxLength": 1000000
        },
        "replaceAll": {
          "type": "boolean"
        }
      },
      "required": [
        "editTargetPath",
        "oldString",
        "newString"
      ],
      "additionalProperties": false
    }
  },
  "$id": "https://buli.dev/schemas/tool-call-request/v1.json",
  "title": "Buli Tool Call Request v1",
  "description": "Provider-requested local tool intent contract."
}
