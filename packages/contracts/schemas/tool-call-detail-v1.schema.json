                  },
                  {
                    "$ref": "#/$defs/__schema6"
                  },
                  {
                    "$ref": "#/$defs/__schema17"
                  },
                  {
                    "$ref": "#/$defs/__schema15"
                  },
                  {
                    "$ref": "#/$defs/__schema8"
                  },
                  {
                    "$ref": "#/$defs/__schema10"
                  },
                  {
                    "$ref": "#/$defs/__schema12"
                  },
                  {
                    "$ref": "#/$defs/__schema13"
                  },
                  {
                    "$ref": "#/$defs/__schema14"
